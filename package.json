{
  "name": "hrms",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "db:generate": "turbo db:generate --filter=@hrms/api",
    "db:migrate": "turbo db:migrate --filter=@hrms/api",
    "db:push": "turbo db:push --filter=@hrms/api",
